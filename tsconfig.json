{
  "compilerOptions": {
    // ─── Language target ──────────────────────────────────────────────────────
    // ES2017+ enables async/await without transpiling to Promise chains.
    // bundler resolution matches how Next.js (via Turbopack/webpack) resolves modules.
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    // ─── Strictness ───────────────────────────────────────────────────────────
    // strict: true enables noImplicitAny, strictNullChecks, and more.
    // This is what makes TypeScript actually useful — loose TypeScript is worse
    // than no TypeScript because it gives false confidence.
    "strict": true,
    "noEmit": true,
    // ─── JSX ─────────────────────────────────────────────────────────────────
    // preserve: Next.js handles JSX transformation itself via SWC/Turbopack.
    "jsx": "react-jsx",
    // ─── Interop ─────────────────────────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    // ─── TypeScript 6 migration ───────────────────────────────────────────────
    // baseUrl is deprecated in TS6 (removed in TS7). Suppressing the warning
    // here until Next.js drops the baseUrl requirement for @/* path aliases.
    // Track: https://aka.ms/ts6 for full migration guidance.
    "ignoreDeprecations": "6.0",
    // ─── Path aliases ────────────────────────────────────────────────────────
    // @/* maps to the project root, so `import { cn } from "@/lib/utils"` works
    // from any depth. Keeps imports clean and refactor-friendly.
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    // ─── Plugins ─────────────────────────────────────────────────────────────
    // next plugin integrates TypeScript checking with Next.js internals
    // (e.g. validates metadata exports, page prop types, etc.)
    "plugins": [
      {
        "name": "next"
      }
    ],
    "skipLibCheck": true,
    "allowJs": true,
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
