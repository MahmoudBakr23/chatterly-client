# ─── API ───────────────────────────────────────────────────────────────────────
# The Rails API base URL. In development this is localhost:3001.
# In production, set to your deployed API domain.
# This var is SERVER-ONLY (no NEXT_PUBLIC_ prefix) — used in Route Handlers only.
# The browser never sees the raw API URL; all calls go through our Next.js proxy layer.
API_URL=http://localhost:3001
# Public API URL for browser-side Axios calls.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Action Cable ──────────────────────────────────────────────────────────────
# WebSocket URL for Action Cable. Must use ws:// in dev, wss:// in prod.
# NEXT_PUBLIC_ prefix is required — the Action Cable consumer runs in the browser.
NEXT_PUBLIC_CABLE_URL=ws://localhost:3001/cable
